APP_ENV=development
APP_NAME=Clinical AI Webapp
DEBUG=true
LOG_LEVEL=info

DATABASE_URL=sqlite:///./clinical_ai.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://USERNAME:PASSWORD@HOST:5432/DBNAME

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

ALLOWED_ORIGINS=http://localhost:3000

GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_SCAN_INTERVAL=300

AI_PROVIDER=perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
PERPLEXITY_FALLBACK_PROMPT_FOR_NEW_KEY=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

OPENAI_API_KEY=
OPENAI_MODEL=

SUMMARY_TEMPLATE_NAME=Clinical_Summary_Template.html
SESSION_TEMPLATE_NAME=Session_Notes_Template.html
TREATMENT_TEMPLATE_NAME=Treatment_Plan_Template.html
PDF_OUTPUT_TMP_DIR=/tmp/clinical-ai

DEFAULT_PAYER=Aetna
EVAL_COMPARISON_ENABLED=true

SUMMARY_AUTO_SAVE_PDF=true
SESSION_NOTE_DEFAULT_MODE=draft
TREATMENT_PLAN_DEFAULT_MODE=review
ENABLE_SAFER_PREVIEW_FLOW=true

ENABLE_DIAGNOSTICS=true
ENABLE_HEALTHCHECKS=true
ENABLE_RENDER_DEBUG_LOGS=true
SAVE_TEMPLATE_RENDER_LOGS=true
SAVE_PLACEHOLDER_DIAGNOSTICS=true

ADMIN_EMAIL=aleix@drzelisko.com
ADMIN_PASSWORD=Admin123
ADMIN_FULL_NAME=Aleixander Puerta

RUN_SEEDS_ON_STARTUP=false
SEED_REIMBURSEMENT_RATES=true
SEED_DEFAULT_SERVICE_TYPES=true
SEED_DEFAULT_CLASSIFICATION_RULES=true
SEED_DEFAULT_WORKFLOW_SETTINGS=true
SEED_DEFAULT_TEMPLATES=true
